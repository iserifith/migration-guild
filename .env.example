# OpenAI-compatible runtime

# DashScope (Alibaba Qwen) — international endpoint, default for Migration Guild
DASHSCOPE_API_KEY=
# Base URL is set per-profile in guildctl.config.json; override here if needed:
# OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Alternative runtimes
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# Optional local OpenAI-compatible endpoint
# OPENAI_BASE_URL=http://localhost:1234/v1
