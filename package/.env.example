# Migration Guild environment variables
# Copy this file to .env and fill in values before running the pipeline.
# Load with: export $(grep -v '^#' .env | xargs)

# ─── Provider (optional) ───────────────────────────────────────────────────────
# Required only when guildctl.config.json has "llmProvider" or "agentProvider"
# set to "provider" / "azure-ai", or when using batch/eval/tracing/agents commands.

# Azure OpenAI endpoint — for chat completions and batch (v1, model in body).
# Format: https://<resource>.openai.azure.com/openai/v1
PROVIDER_OPENAI_ENDPOINT=

# Azure Cognitive Services endpoint — for embeddings.
# Format: https://<resource>.cognitiveservices.azure.com/openai/v1
PROVIDER_EMBED_ENDPOINT=

# OpenAI-compatible provider project endpoint — for Agents, Threads, and Evals.
# Format: https://<resource>.services.ai.azure.com/api/projects/<project>
PROVIDER_PROJECT_ENDPOINT=

# OpenAI-compatible provider API key (same key works for both endpoints)
PROVIDER_API_KEY=

# ─── Registry ─────────────────────────────────────────────────────────────────
# Override the default SQLite database path (default: migration/registry.db).
# Useful when running multiple migration projects from the same directory,
# or when the workspace root differs from the working directory.
# REGISTRY_DB=

# ─── agent CLI ──────────────────────────────────────────────────────────────
# Name or full path of the agent CLI binary (default: agent).
# Change this if your binary is named differently, e.g. "gh" or "/usr/local/bin/agent".
AGENT_CMD=agent

# ─── Dashboard ────────────────────────────────────────────────────────────────
# Number of minutes before a claimed artifact is flagged as stalled in
# "Migration Guild watch" (default: 10).
GUILDCTL_STALL_MINS=10
