# OpenAI-compatible runtime

# DashScope (Alibaba Qwen) — international endpoint, default for Migration Guild
DASHSCOPE_API_KEY=
# Base URL is set per-profile in guildctl.config.json; override here if needed:
# OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Agent harness — guildctl shells out to this for each phase. agent-shim.mjs
# adapts the GitHub Copilot CLI to run against DashScope (BYOK). Path is
# relative to the workspace root, which is guildctl's spawn cwd.
AGENT_CMD=agent-shim.mjs
# Pin the Copilot CLI entry only if auto-detection fails:
# COPILOT_CLI_ENTRY=C:\Users\<you>\AppData\Local\copilot\pkg\win32-x64\<ver>\index.js

# Alternative runtimes
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# Optional local OpenAI-compatible endpoint
# OPENAI_BASE_URL=http://localhost:1234/v1
